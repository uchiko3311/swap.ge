.logo img {
    height: 45px;            /* ლოგოს სიმაღლე */
    width: 45px;             /* ლოგოს სიგანე (რადგან კვადრატულია) */
    object-fit: cover;       /* სურათი არ გაიწელოს */
    border-radius: 10px;     /* კუთხეების ოდნავ დამრგვალება */
    box-shadow: 0 2px 5px rgba(0,0,0,0.1); /* მსუბუქი ჩრდილი ეფექტისთვის */
    vertical-align: middle;  /* ტექსტთან გასწორება */
}
