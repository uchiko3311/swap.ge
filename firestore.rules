rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // მომხმარებლის პროფილის წესები
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // განცხადებების (პოსტების) წესები
    match /items/{itemId} {
      allow read: if true; // ყველას შეუძლია ნახვა
      
      allow create: if request.auth != null 
        && request.resource.data.images.size() <= 14 // მაქსიმუმ 14 ფოტო
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.postLimit > 0;

      allow update, delete: if request.auth != null 
        && (resource.data.ownerId == request.auth.uid || request.auth.token.email == "admin@gmail.com");
    }

    // ბანერების წესები (მხოლოდ ადმინისთვის)
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "admin@gmail.com";
    }
  }
}
